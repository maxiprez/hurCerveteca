              </svg>
            </div>
            <div class="channel-text">
              <strong>WhatsApp</strong>
              <span>Respondemos en minutos</span>
            </div>
            <svg class="channel-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>

          <a
            href="https://instagram.com/hurcerveteca"
            target="_blank"
            rel="noopener"
            class="channel-card"
          >
            <div class="channel-icon instagram">
              <svg viewBox="0 0 24 24" fill="currentColor" width="28" height="28">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
              </svg>
            </div>
            <div class="channel-text">
              <strong>Instagram</strong>
              <span>@hurcerveteca</span>
            </div>
            <svg class="channel-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .contact {
    background: var(--black);
  }

  .contact-inner {
    position: relative;
    border-radius: calc(var(--radius-lg) * 2);
    overflow: hidden;
    min-height: 400px;
    display: flex;
    align-items: center;
  }

  .contact-bg-img {
    position: absolute;
    inset: 0;
  }

  .contact-bg-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.3) saturate(0.5);
  }

  .contact-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      90deg,
      rgba(10, 10, 10, 0.95) 0%,
      rgba(10, 10, 10, 0.8) 50%,
      rgba(10, 10, 10, 0.6) 100%
    );
  }

  .contact-content {
    position: relative;
    z-index: 1;
    padding: 4rem;
    max-width: 640px;
  }

  .contact-title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 4rem);
    color: var(--white);
    line-height: 1;
    margin-bottom: 1rem;
    letter-spacing: 0.02em;
  }

  .contact-title em {
    font-family: var(--font-accent);
    font-style: italic;
    color: var(--gold);
  }

  .contact-desc {
    font-size: 0.95rem;
    color: var(--gray-light);
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .contact-channels {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .channel-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.25rem;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-lg);
    transition: background var(--transition), border-color var(--transition), transform var(--transition);
    backdrop-filter: blur(8px);
  }

  .channel-card:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: var(--gold);
    transform: translateX(4px);
  }

  .channel-icon {
    width: 48px;
    height: 48px;
    border-radius: var(--radius);
    display: grid;
    place-items: center;
    flex-shrink: 0;
  }

  .channel-icon.whatsapp {
    background: rgba(37, 211, 102, 0.15);
    color: #25d366;
  }

  .channel-icon.instagram {
    background: rgba(225, 48, 108, 0.15);
    color: #e1306c;
  }

  .channel-text {
    display: flex;
    flex-direction: column;
    flex: 1;
    gap: 0.1rem;
  }

  .channel-text strong {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--white);
  }

  .channel-text span {
    font-size: 0.8rem;
    color: var(--gray);
  }

  .channel-arrow {
    color: var(--gray);
    transition: color var(--transition), transform var(--transition);
  }

  .channel-card:hover .channel-arrow {
    color: var(--gold);
    transform: translateX(4px);
  }

  @media (max-width: 640px) {
    .contact-content {
      padding: 2.5rem 1.5rem;
    }
  }
</style>
