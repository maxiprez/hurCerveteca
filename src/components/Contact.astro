<section class="contact" id="contacto">
  <div class="container">
    <div class="contact-inner fade-up">
      <div class="contact-bg-img">
        <img src="/images/bottles.webp" alt="" aria-hidden="true" />
        <div class="contact-overlay"></div>
      </div>

      <div class="contact-content">
        <span class="section-label">Contacto</span>
        <h2 class="contact-title">
          ¿Tenés alguna<br /><em>consulta?</em>
        </h2>
        <p class="contact-desc">
          Escribinos por WhatsApp, seguinos en Instagram o pasate directo por el local.
          Siempre hay alguien para ayudarte a encontrar lo que buscás.
        </p>

        <div class="contact-channels">
          <a
            href="https://wa.me/5491100000000?text=Hola%20Hur!%20Quiero%20consultar%20sobre%20stock%20y%20precios."
            target="_blank"
            rel="noopener"
            class="channel-card"
          >
            <div class="channel-icon whatsapp">
              <svg viewBox="0 0 24 24" fill="currentColor" width="28" height="28">
