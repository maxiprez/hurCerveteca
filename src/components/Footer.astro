---
const currentYear = new Date().getFullYear();

const links = [
  { label: 'Nosotros', href: '#nosotros' },
  { label: 'Productos', href: '#categorias' },
  { label: 'Destacados', href: '#destacados' },
  { label: 'Ubicación', href: '#ubicacion' },
  { label: 'Contacto', href: '#contacto' },
];
---

<footer class="footer">
  <div class="container">
    <div class="footer-top">
      <div class="footer-brand">
        <img src="/images/logo_hur.webp" alt="Hur Cerveteca" class="footer-logo" />
        <p class="footer-tagline">
          Tu rincón cervecero en Hurlingham.<br />
          Cervezas artesanales, importadas, vinos y más.
        </p>
        <div class="footer-social">
          <a
            href="https://instagram.com/hurcerveteca"
            target="_blank"
            rel="noopener"
            class="social-btn"
            aria-label="Instagram"
          >
            <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
            </svg>
          </a>
          <a
            href="https://wa.me/5491171917940"
            target="_blank"
            rel="noopener"
            class="social-btn"
            aria-label="WhatsApp"
          >
            <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347zM12 0C5.373 0 0 5.373 0 12c0 2.123.558 4.112 1.528 5.836L.057 23.454a.5.5 0 00.611.611l5.618-1.471A11.945 11.945 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.792 9.792 0 01-4.988-1.363l-.356-.212-3.694.968.987-3.595-.232-.369A9.818 9.818 0 012.182 12C2.182 6.558 6.558 2.182 12 2.182S21.818 6.558 21.818 12 17.442 21.818 12 21.818z"/>
            </svg>
          </a>
        </div>
      </div>

      <nav class="footer-nav">
        <h4 class="footer-nav-title">Navegación</h4>
        <ul>
          {links.map(l => (
            <li>
              <a href={l.href} class="footer-link">{l.label}</a>
            </li>
          ))}
        </ul>
      </nav>

      <div class="footer-contact-info">
        <h4 class="footer-nav-title">Contacto</h4>
        <div class="footer-detail">
          <span class="detail-label">Dirección</span>
          <span>Av. Vergara 3141, Hurlingham</span>
        </div>
        <div class="footer-detail">
          <span class="detail-label">Horarios</span>
          <span>Lun–Vie: 14 a 22 hs<br />Sáb: 11 a 22 hs<br />Dom: 11 a 20 hs</span>
        </div>
        <div class="footer-detail">
          <span class="detail-label">WhatsApp</span>
          <a href="https://wa.me/5491171917940" class="footer-link">+54 9 11 7191-7940</a>
        </div>
        <div class="footer-detail">
          <span class="detail-label">Instagram</span>
          <a href="https://instagram.com/hurcerveteca" target="_blank" rel="noopener" class="footer-link">@hurcerveteca</a>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <p class="footer-copy">
        © {currentYear} Hur Cerveteca — Hurlingham, Buenos Aires.
      </p>
      <p class="footer-legal">
        Venta de bebidas alcohólicas prohibida a menores de 18 años.
      </p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--dark);
    border-top: 1px solid rgba(212, 160, 23, 0.15);
    padding-top: 4rem;
    padding-bottom: 2rem;
  }

  .footer-top {
    display: grid;
    grid-template-columns: 2fr 1fr 1.5fr;
    gap: 3rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    margin-bottom: 2rem;
  }

  .footer-logo {
    height: 56px;
    width: auto;
    object-fit: contain;
    margin-bottom: 1rem;
    filter: brightness(1.1);
  }

  .footer-tagline {
    font-size: 0.875rem;
    color: var(--gray);
    line-height: 1.7;
    margin-bottom: 1.25rem;
  }

  .footer-social {
    display: flex;
    gap: 0.5rem;
  }

  .social-btn {
    width: 36px;
    height: 36px;
    background: var(--dark-2);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--radius);
    display: grid;
    place-items: center;
    color: var(--gray-light);
    transition: background var(--transition), color var(--transition), border-color var(--transition);
  }

  .social-btn:hover {
    background: var(--gold);
    color: var(--black);
    border-color: var(--gold);
  }

  .footer-nav-title {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 1rem;
  }

  .footer-nav ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .footer-link {
    font-size: 0.875rem;
    color: var(--gray-light);
    transition: color var(--transition);
  }

  .footer-link:hover {
    color: var(--gold);
  }

  .footer-contact-info {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }

  .footer-detail {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .detail-label {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--gold-dim);
  }

  .footer-detail span:not(.detail-label),
  .footer-detail a {
    font-size: 0.85rem;
    color: var(--gray-light);
    line-height: 1.5;
  }

  .footer-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .footer-copy {
    font-size: 0.8rem;
    color: var(--gray);
  }

  .footer-legal {
    font-size: 0.7rem;
    color: var(--gray);
    font-style: italic;
  }

  @media (max-width: 900px) {
    .footer-top {
      grid-template-columns: 1fr 1fr;
    }

    .footer-brand {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 560px) {
    .footer-top {
      grid-template-columns: 1fr;
    }

    .footer-bottom {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
